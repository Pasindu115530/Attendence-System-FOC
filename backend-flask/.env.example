# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
DB_HOST=your_supabase_host
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_password

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads/medical

# ── AWS Rekognition ───────────────────────────────────────────────────────────
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY blank on EC2 with IAM Role.
# For LOCAL development only, fill them in from your IAM user's access keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# The Rekognition Collection name (created once via scripts/setup_collection.py)
REKOGNITION_COLLECTION=attendance-students

# Minimum confidence % to accept a face match (90 = production safe)
FACE_MATCH_THRESHOLD=90

# ── S3 (optional audit trail) ─────────────────────────────────────────────────
# Leave blank to disable S3 storage of face images.
S3_BUCKET=
